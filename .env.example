# Docker Compose local infrastructure
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=crawler
MYSQL_USER=crawler
MYSQL_PASSWORD=crawler
MYSQL_PORT=3306
ADMINER_PORT=8081

# Host-run Go service
INTERVIEW_CRAWLER_HTTP_ADDR=:8080
INTERVIEW_CRAWLER_MYSQL_DSN=crawler:crawler@tcp(127.0.0.1:3306)/crawler?parseTime=true&charset=utf8mb4
INTERVIEW_CRAWLER_NOWCODER_BASE_URL=https://gw-c.nowcoder.com
INTERVIEW_CRAWLER_LLM_API_KEY=replace-me
INTERVIEW_CRAWLER_LLM_BASE_URL=https://api.openai.com
INTERVIEW_CRAWLER_LLM_MODEL=gpt-4.1-mini
INTERVIEW_CRAWLER_SCHEDULE_ENABLED=false
INTERVIEW_CRAWLER_SCHEDULE_INTERVAL=1h
INTERVIEW_CRAWLER_SCHEDULE_PLATFORMS=nowcoder
INTERVIEW_CRAWLER_SCHEDULE_KEYWORDS=面经
INTERVIEW_CRAWLER_SCHEDULE_PAGES=1
